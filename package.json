{
  "name": "bugrepro",
  "version": "0.1.0",
  "description": "Package sanitized local repro bundles from failing commands.",
  "type": "module",
  "bin": {
    "bugrepro": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/redaction.md",
    "docs/replay-safety.md",
    "docs/PRD.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "release:check": "npm test && npm run check && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "bug-report",
    "repro",
    "cli",
    "redaction",
    "fixtures"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/bugrepro.git"
  },
  "homepage": "https://github.com/rogerchappel/bugrepro#readme",
  "bugs": {
    "url": "https://github.com/rogerchappel/bugrepro/issues"
  }
}
